# =============================================================================
# Stripe → Metronome Sidecar configuration
# Copy this file to `.env` for local development. Never commit `.env`.
# =============================================================================

# -----------------------------------------------------------------------------
# Required
# -----------------------------------------------------------------------------

# Stripe webhook signing secret from the Stripe Dashboard (or `stripe listen`).
# Used to verify the authenticity of every incoming webhook.
STRIPE_WEBHOOK_SECRET=whsec_replace_me

# Metronome API bearer token. Treat as a secret — full read/write on your org.
METRONOME_API_KEY=replace_me

# SQLAlchemy-style async Postgres URL. The asyncpg driver is required.
# For docker-compose this points at the `db` service.
DATABASE_URL=postgresql+asyncpg://sidecar:localdev@db:5432/sidecar

# Metronome rate card UUID used for every contract this sidecar creates.
# Find it in the Metronome dashboard under Rate Cards. v0.2a binds every
# subscription contract to this rate card; per-customer overrides are out
# of scope (and would belong in src/sidecar/mappers/subscription.py).
METRONOME_DEFAULT_RATE_CARD_ID=replace_me_rate_card_uuid

# -----------------------------------------------------------------------------
# Optional (with sensible defaults)
# -----------------------------------------------------------------------------

# Python log level: DEBUG | INFO | WARNING | ERROR | CRITICAL
LOG_LEVEL=INFO

# How often (seconds) the worker checks the queue when it finds no work.
WORKER_POLL_INTERVAL_SECONDS=2

# Maximum number of times the worker will attempt to process an event before
# marking it `failed`. Failed events stay in the database for operator triage.
WORKER_MAX_ATTEMPTS=5

# Base delay (seconds) for the worker's exponential backoff. The nth retry is
# scheduled at min(BASE * 2^(attempts-1), CAP) seconds from now, plus jitter.
WORKER_RETRY_BASE_SECONDS=30
WORKER_RETRY_CAP_SECONDS=3600

# Override only if you need to point at a non-production Metronome environment.
METRONOME_BASE_URL=https://api.metronome.com

# Port the FastAPI receiver listens on.
PORT=8000
